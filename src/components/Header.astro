---
const pathname = Astro.url.pathname;

const navItems = [
  { href: '/', label: '首页' },
  { href: '/series/junior', label: '初级专栏' },
  { href: '/series/senior', label: '高级专栏' },
  { href: '/about', label: '关于' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="sticky top-0 z-50 border-b border-cyan-500/20 bg-dark/90 backdrop-blur-md">
  <div class="max-w-5xl mx-auto px-4">
    <div class="flex items-center justify-between h-14">
      <a href="/" class="flex items-center gap-2 text-white font-semibold shrink-0">
        <svg class="h-5 w-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 8V4H8"/>
          <rect width="16" height="12" x="4" y="8" rx="2"/>
          <path d="M2 14h2"/><path d="M20 14h2"/>
          <path d="M15 13v2"/><path d="M9 13v2"/>
        </svg>
        <span>Conor's Blog</span>
      </a>

      {/* Desktop nav */}
      <div class="hidden md:flex items-center gap-1">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={[
              'px-3 py-2 rounded-lg text-sm font-medium transition-colors',
              isActive(item.href)
                ? 'text-accent bg-accent/10'
                : 'text-slate-400 hover:text-slate-200 hover:bg-slate-800/80',
            ]}
          >
            {item.label}
          </a>
        ))}
        <span class="w-px h-4 bg-slate-600 mx-2"></span>
        <a
          href="https://resume.conorliu.com"
          target="_blank"
          rel="noopener"
          class="px-3 py-2 rounded-lg text-sm font-medium text-slate-400 hover:text-slate-200 hover:bg-slate-800/80 transition-colors"
        >
          简历 ↗
        </a>
      </div>

      {/* Mobile menu button */}
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden p-2 rounded-lg text-slate-400 hover:text-slate-200 hover:bg-slate-800/80"
        aria-label="打开菜单"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
</nav>

{/* Mobile slide-out menu */}
<div id="mobile-menu-overlay" class="fixed inset-0 z-[60] md:hidden pointer-events-none" aria-hidden="true">
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-black/60 backdrop-blur-sm opacity-0 transition-opacity duration-200"></div>
  <div id="mobile-menu-panel" class="absolute top-0 right-0 bottom-0 w-[min(18rem,85vw)] bg-slate-900 border-l border-slate-700 shadow-xl flex flex-col translate-x-full transition-transform duration-200 ease-out">
    <div class="flex items-center justify-between h-14 px-4 border-b border-slate-700">
      <span class="text-sm font-medium text-slate-300">导航</span>
      <button id="mobile-menu-close" type="button" class="p-2 rounded-lg text-slate-400 hover:text-white hover:bg-slate-800" aria-label="关闭菜单">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="flex-1 overflow-y-auto py-4">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={[
            'flex items-center px-4 py-3 text-sm font-medium border-b border-slate-800/50 last:border-0 transition-colors',
            isActive(item.href)
              ? 'text-accent bg-accent/10'
              : 'text-slate-400 hover:text-slate-200 hover:bg-slate-800/80',
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href="https://resume.conorliu.com"
        target="_blank"
        rel="noopener"
        class="flex items-center px-4 py-3 text-sm font-medium text-slate-400 hover:text-slate-200 hover:bg-slate-800/80"
      >
        简历 ↗
      </a>
    </div>
  </div>
</div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const close = document.getElementById('mobile-menu-close');
  const overlay = document.getElementById('mobile-menu-overlay');
  const backdrop = document.getElementById('mobile-menu-backdrop');
  const panel = document.getElementById('mobile-menu-panel');

  function openMenu() {
    overlay!.classList.replace('pointer-events-none', 'pointer-events-auto');
    overlay!.setAttribute('aria-hidden', 'false');
    backdrop!.classList.replace('opacity-0', 'opacity-100');
    panel!.classList.replace('translate-x-full', 'translate-x-0');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    backdrop!.classList.replace('opacity-100', 'opacity-0');
    panel!.classList.replace('translate-x-0', 'translate-x-full');
    document.body.style.overflow = '';
    setTimeout(() => {
      overlay!.classList.replace('pointer-events-auto', 'pointer-events-none');
      overlay!.setAttribute('aria-hidden', 'true');
    }, 200);
  }

  btn?.addEventListener('click', openMenu);
  close?.addEventListener('click', closeMenu);
  backdrop?.addEventListener('click', closeMenu);
</script>
