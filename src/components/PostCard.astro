---
interface Props {
  title: string;
  description: string;
  href: string;
  order: number;
  tags?: string[];
  publishDate?: string;
}

const { title, description, href, order, tags = [], publishDate } = Astro.props;
---

<a href={href} class="glass-card block group p-5 sm:p-6">
  <div class="flex items-start gap-4">
    <span class="shrink-0 w-10 h-10 rounded-lg bg-accent/10 border border-accent/20 flex items-center justify-center text-accent font-mono text-sm font-bold">
      {String(order).padStart(2, '0')}
    </span>
    <div class="min-w-0 flex-1">
      <h3 class="text-white font-semibold text-base group-hover:text-accent transition-colors leading-snug">
        {title}
      </h3>
      <p class="text-sm text-slate-400 mt-1.5 line-clamp-2">{description}</p>
      <div class="flex items-center gap-3 mt-3">
        {publishDate && (
          <time class="text-xs text-slate-500 font-mono">{publishDate}</time>
        )}
        {tags.length > 0 && (
          <div class="flex gap-1.5 flex-wrap">
            {tags.slice(0, 3).map(tag => (
              <span class="text-xs px-2 py-0.5 rounded-full bg-accent/8 border border-accent/15 text-cyan-300/80">
                {tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </div>
    <svg class="shrink-0 w-5 h-5 text-slate-600 group-hover:text-accent group-hover:translate-x-0.5 transition-all mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
    </svg>
  </div>
</a>
