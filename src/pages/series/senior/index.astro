---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('senior'))
  .filter(p => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="高级前端的 AI 架构升级之路" description="面向 5 年以上前端，聚焦 AI 网关、状态管理、Streaming 架构、多 Agent 系统设计">
  <div class="max-w-4xl mx-auto px-4 py-10">

    <a href="/" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-accent transition-colors mb-6">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      返回首页
    </a>

    <header class="mb-10">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs px-2.5 py-1 rounded-full border bg-purple-500/10 border-purple-500/25 text-purple-300 font-medium">
          高级
        </span>
        <span class="text-xs text-slate-500 font-mono">{posts.length} 篇已发布 · 计划 23 篇</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-bold text-white mb-3">
        高级前端的 AI 架构升级之路
      </h1>
      <p class="text-slate-400 leading-relaxed max-w-2xl">
        面向 5 年以上前端和技术负责人。你不缺写代码的能力，缺的是 AI 时代的架构视野。聚焦 AI 网关设计、多 Agent 系统、内部 AI 平台搭建、Prompt 工程化管理、产品度量与商业化。
      </p>
    </header>

    <div class="space-y-3">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          href={`/series/senior/${post.id}`}
          order={post.data.order}
          tags={post.data.tags}
          publishDate={post.data.publishDate}
        />
      ))}
    </div>

    {/* Upcoming */}
    <div class="mt-10 section-panel p-6">
      <h3 class="text-sm font-semibold text-slate-400 mb-3">即将更新</h3>
      <ul class="space-y-2 text-sm text-slate-500">
        <li class="flex items-center gap-2"><span class="w-6 text-center font-mono text-slate-600">24</span> 知识库工程化：文件解析、分片策略、存储架构设计</li>
        <li class="flex items-center gap-2"><span class="w-6 text-center font-mono text-slate-600">25</span> 向量数据库深度对比与生产选型</li>
        <li class="flex items-center gap-2"><span class="w-6 text-center font-mono text-slate-600">26</span> 意图识别系统设计：从关键词匹配到语义路由</li>
      </ul>
    </div>

  </div>
</BaseLayout>
