---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PostCard from '@/components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('junior'))
  .filter(p => !p.data.draft)
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="前端转 AI 全栈实战" description="从零起步的 AI 全栈实战指南，JS/TS + Python 双语言并进">
  <div class="max-w-4xl mx-auto px-4 py-10">

    <a href="/" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-accent transition-colors mb-6">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
      返回首页
    </a>

    <header class="mb-10">
      <div class="flex items-center gap-2 mb-3">
        <span class="text-xs px-2.5 py-1 rounded-full border bg-cyan-500/10 border-cyan-500/25 text-cyan-300 font-medium">
          初级
        </span>
        <span class="text-xs text-slate-500 font-mono">{posts.length} 篇已发布 · 计划 26 篇</span>
      </div>
      <h1 class="text-2xl md:text-3xl font-bold text-white mb-3">
        前端转 AI 全栈实战
      </h1>
      <p class="text-slate-400 leading-relaxed max-w-2xl">
        一个真实转型过来的前端，带你走向 AI 全栈。从调通第一个 AI API 开始，JS/TS + Python 双语言并进，逐步掌握 Prompt 工程、流式渲染、FastAPI 后端、RAG、Agent、MCP 协议等核心能力。
      </p>
    </header>

    <div class="space-y-3">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          href={`/series/junior/${post.id}`}
          order={post.data.order}
          tags={post.data.tags}
          publishDate={post.data.publishDate}
        />
      ))}
    </div>

    {/* Upcoming */}
    <div class="mt-10 section-panel p-6">
      <h3 class="text-sm font-semibold text-slate-400 mb-3">即将更新</h3>
      <ul class="space-y-2 text-sm text-slate-500">
        <li class="flex items-center gap-2"><span class="w-6 text-center font-mono text-slate-600">06</span> Prompt 工程：前端最容易忽略的核心技能</li>
        <li class="flex items-center gap-2"><span class="w-6 text-center font-mono text-slate-600">07</span> .env 管理、代理配置、错误处理——AI 应用的工程化基础</li>
        <li class="flex items-center gap-2"><span class="w-6 text-center font-mono text-slate-600">08</span> 从脚本到 CLI 工具：用 Node.js 打造你的第一个 AI 命令行工具</li>
      </ul>
    </div>

  </div>
</BaseLayout>
